# Web UI built assets — large JS/CSS files from `make ui` are not committed.
# Only server/web/ui/index.html (the placeholder/entry point) is tracked in git.
# The assets/ directory is generated by `make ui` and embedded at compile time.
server/web/ui/assets/

# node_modules
webui/node_modules/

# Flag to show that go-assets.sh has been run
.downloaded_assets

# Proto backup directories created by fix_proto.sh
.proto_backup_*/
